# Doxygen Configuration File
# Auto-documentation generation for Dual-RAG-Evaluator

PROJECT_NAME           = "Dual-RAG-Evaluator"
PROJECT_NUMBER         = "1.0.0"
PROJECT_BRIEF          = "Compare ChromaDB vs ResonanceDB with negation support"

OUTPUT_DIRECTORY       = ./docs/_build/doxygen

CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

OUTPUT_LANGUAGE        = English

# Input sources
INPUT                  = ./src
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.py
RECURSIVE              = YES

# Documentation options
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

# Code filtering
SKIP_FUNCTION_MACROS   = YES

# HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_THEME             = doxygen

# LaTeX output
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
LATEX_CMD_NAME         = latex

# RTF output
GENERATE_RTF           = NO

# Man pages
GENERATE_MAN           = NO

# XML output
GENERATE_XML           = YES
XML_OUTPUT             = xml

# Docset output
GENERATE_DOCSET        = NO

# HTML Help output
GENERATE_HTMLHELP      = NO

# Qt Help output
GENERATE_QHP           = NO

# Search engine
SEARCHENGINE           = YES

# Mathjax support
USE_MATHJAX            = YES
MATHJAX_FORMAT         = HTML-CSS

# Preprocessing
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO

# Dependencies
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = ./src

# Formatting
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ENDS_AT_NEWLINE = NO

# Symbols
SYMBOL_CACHE_SIZE      = 0

# Build settings
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

# Colors
HTML_COLORSTYLE = AUTO

# Output
USE_MDFILE_AS_MAINPAGE = README.md

# Grouping
GROUP_NESTED_CLASSES   = YES

# Advanced
SORT_BY_SCOPE_NAME     = NO
GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST = YES

# Clang integration (for better parsing)
CLANG_ASSISTED_PARSING = NO

# Dynamic sections
DYNAMIC_SECTIONS       = NO

# Collaboration diagram settings
MAX_DOT_GRAPH_DEPTH    = 0
DOT_GRAPH_MAX_NODES    = 50

# Image formats
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
DOT_FONTNAME           = Helvetica
DOT_FONTSIZE           = 10
