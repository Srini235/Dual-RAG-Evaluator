# Environment Configuration Template
# Copy this file to config/.env and fill in your values
# WARNING: Never commit actual secrets to git!

# ======================
# Application Settings
# ======================
APP_NAME=Dual-RAG-Evaluator
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# ======================
# Database / Storage
# ======================
DATA_PATH=./data
RESULTS_PATH=./results
CACHE_PATH=./data/cache

# ======================
# Embedding Model
# ======================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ======================
# ChromaDB Configuration
# ======================
CHROMADB_PATH=./data/embeddings/chromadb
CHROMADB_COLLECTION_NAME=medical_documents

# ======================
# ResonanceDB Configuration
# ======================
RESONANCEDB_HOST=localhost
RESONANCEDB_PORT=31415
RESONANCEDB_API_TIMEOUT=30
RESONANCEDB_ENABLED=False
RESONANCEDB_USE_MOCK=True

# ======================
# RAG Settings
# ======================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
MIN_SIMILARITY_THRESHOLD=0.3

# ======================
# Negation Detection
# ======================
NEGATION_ENABLED=True
NEGATION_WORDS=not,never,without,no,none,absence,lack,cannot,does not

# ======================
# Document Processing
# ======================
MAX_FILE_SIZE_MB=10
SUPPORTED_FORMATS=pdf,txt,docx,md
EXTRACT_TEXT_PREVIEW=True
TEXT_PREVIEW_LENGTH=500

# ======================
# UI Settings
# ======================
UI_THEME=default
WINDOW_WIDTH=1400
WINDOW_HEIGHT=900
SHOW_SIMILARITY_SCORES=True
SHOW_EXECUTION_TIME=True

# ======================
# Export Settings
# ======================
EXPORT_FORMATS=pdf,csv,json,html
EXPORT_PATH=./results

# ======================
# API Keys (for future extensions)
# ======================
OPENAI_API_KEY=your_key_here
HUGGINGFACE_API_TOKEN=your_token_here

# ======================
# Advanced Settings
# ======================
BATCH_PROCESSING=False
CACHE_ENABLED=True
SIMILARITY_METRIC=cosine
PHASE_DETECTION_ENABLED=True
